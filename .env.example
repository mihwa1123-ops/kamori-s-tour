# =============================================================
# kamori's tour — 환경 변수 예시
# -------------------------------------------------------------
# 실제 값은 .env.local 에 저장 (gitignore 대상).
# CI 는 GitHub Secrets 사용.
# =============================================================

# ----- Chromatic (Storybook 시각 회귀 테스트) -----
# 발급: https://www.chromatic.com → 프로젝트 → Manage → Project token
# 로컬에서 `npx chromatic` 실행 시 필요. CI 는 GitHub Secrets 의 CHROMATIC_PROJECT_TOKEN 참조.
CHROMATIC_PROJECT_TOKEN=

# ----- Kakao Map (추후 지도 통합 시) -----
# 발급: https://developers.kakao.com/console/app
# Vite 환경 변수는 VITE_ 접두사 필요 (브라우저 노출).
# VITE_KAKAO_MAP_KEY=

# ----- Analytics (추후 GA4 등) -----
# VITE_GA_MEASUREMENT_ID=
